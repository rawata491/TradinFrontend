# Leave empty in development — Vite proxy forwards /api and /ws to the backend.
# Production values live in `.env.production` (used by `vite build` and Docker).
VITE_API_BASE_URL=
# Optional override — if set to ws:// on HTTPS, it is auto-upgraded to wss://
VITE_WS_URL=
VITE_APP_NAME=Tradin
# Google OAuth client ID (Web application) — same value as GOOGLE_OAUTH_CLIENT_ID on backend
VITE_GOOGLE_CLIENT_ID=
